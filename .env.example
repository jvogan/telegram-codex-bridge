# Required for the base Telegram bridge.
# Create a Telegram bot first, then place its token here.
TELEGRAM_BOT_TOKEN=

# Optional OpenAI-backed features.
# Enables OpenAI ASR, OpenAI image generation, and live /call.
OPENAI_API_KEY=

# Optional TTS fallback or override.
ELEVENLABS_API_KEY=

# Optional image fallback or override.
GOOGLE_GENAI_API_KEY=

# Optional image routing mode: bridge-direct (default) or codex-native.
TELEGRAM_IMAGE_GENERATION_MODE=bridge-direct

# Required only if you enable live /call.
# Use a long random secret and keep it out of git.
REALTIME_CONTROL_SECRET=
